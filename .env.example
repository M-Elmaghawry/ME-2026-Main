# EmailJS credentials — get them from https://www.emailjs.com/
# 1. Create a free account at emailjs.com
# 2. Add Gmail as a service → copy the Service ID
# 3. Create an email template → copy the Template ID
# 4. Go to Account → API Keys → copy the Public Key

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Optional: force HashRouter (for GitHub Pages static hosting)
# VITE_FORCE_HASH_ROUTER=true

# Optional: custom base path
# VITE_BASE_PATH=/
